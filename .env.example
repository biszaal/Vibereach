# ── AWS ──────────────────────────────────────────────────────────────
# IAM credentials with DynamoDB access (waitlist table)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# DynamoDB table name (matches CloudFormation output)
WAITLIST_TABLE_NAME=vibereach-waitlist-prod

# ── Resend (transactional email) ──────────────────────────────────────
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────
# Used to generate referral URLs in confirmation emails
NEXT_PUBLIC_APP_URL=https://vibereach.io
