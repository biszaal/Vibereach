# ── AWS ──────────────────────────────────────────────────────────────
# IAM credentials — needs DynamoDB + future Lambda access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# DynamoDB table names (match CloudFormation outputs)
WAITLIST_TABLE_NAME=vibereach-waitlist-prod
PROJECTS_TABLE_NAME=vibereach-projects-prod

# ── AI ────────────────────────────────────────────────────────────────
# Anthropic API key — used server-side only, never exposed to client
ANTHROPIC_API_KEY=

# ── Email ─────────────────────────────────────────────────────────────
# Resend — transactional email (confirmations, audit reports, digests)
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────
# Used to generate referral URLs, email links, etc.
NEXT_PUBLIC_APP_URL=https://vibereach.io

# ── Reddit OAuth ──────────────────────────────────────────────────────
# Register at https://www.reddit.com/prefs/apps — "web app" type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── SQS (drip posting queue) ──────────────────────────────────────────
# FIFO queue URL from CloudFormation output PostingQueueUrl
SQS_QUEUE_URL=

# ── DynamoDB (additional tables) ─────────────────────────────────────
REDDIT_TABLE_NAME=vibereach-reddit-posts-prod
ACCOUNTS_TABLE_NAME=vibereach-accounts-prod
AUDIT_TABLE_NAME=vibereach-audit-reports-prod
